# Supabase project URL — SOLO la base, SIN /rest/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Clave publishable (sb_publishable_...) o legacy anon (eyJ...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Alias aceptado:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Clave secret (sb_secret_...) o legacy service_role
SUPABASE_SERVICE_ROLE_KEY=
# Alias aceptado:
# SUPABASE_SECRET_KEY=

# Plugin API security (optional — enforces X-Kitch-Signature when set)
KITCH_API_HMAC_SECRET=

# Payment webhooks (Phase 4 — optional until Stripe/Wompi live)
# STRIPE_WEBHOOK_SECRET=
# WOMPI_EVENTS_SECRET=

# Canonical site URL
NEXT_PUBLIC_SITE_URL=https://flowkitch.com

# Hostinger production (optional — set in hPanel)
# HOSTNAME=0.0.0.0
# NODE_OPTIONS=--max-old-space-size=512
# UV_THREADPOOL_SIZE=2

# WhatsApp lead (existing)
NEXT_PUBLIC_WHATSAPP_WA_LINK=
NEXT_PUBLIC_WHATSAPP_E164=
